{
  "$schema": "https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v2.4.0/crudapiplugin.apifile.schema.json",
  "baseUrl": "http://api.ristorante.com/dishes",
  "dataFile": "dishes-data.json",
  "auth": "entra",
  "entraAuthConfig": {
    "audience": "<ENTRA_APP_CLIENT_ID>",
    "issuer": "https://login.microsoftonline.com/<ENTRA_APP_TENANT_ID>/v2.0"
  },
  "actions": [
    {
      "action": "getAll"
    },
    {
      "action": "getOne",
      "url": "/{dish-id}",
      "query": "$.[?(@.id == {dish-id})]"
    }
  ]
}