{
  "$kind": "BotConfiguration",
  "channels": [
    {
      "$kind": "ChannelDefinition",
      "channelId": "MsTeams"
    }
  ],
  "settings": {
    "GenerativeActionsEnabled": true
  },
  "isAgentConnectable": true,
  "gPTSettings": {
    "$kind": "GPTSettings",
    "defaultSchemaName": "cr7f7_blogHelperAgent.gpt.default"
  },
  "isLightweightBot": false,
  "aISettings": {
    "$kind": "AISettings",
    "useModelKnowledge": true,
    "isFileAnalysisEnabled": true,
    "isSemanticSearchEnabled": true,
    "contentModeration": "High",
    "optInUseLatestModels": false
  },
  "recognizer": {
    "$kind": "GenerativeAIRecognizer"
  },
  "analyticsSettings": {
    "$kind": "AnalyticsSettings",
    "includeNodeLevelDetailsInTranscript": true
  }
}