{
    "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
    "manifestVersion": "1.19",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Contoso",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termsofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Executive Helper",
        "full": "Executive Helper"
    },
    "description": {
        "short": "Generates professional bios of meeting participants for better engagement.",
        "full": "Generates short, professional bios of meeting participants so leaders quickly understand others' background, role, and expertise before meetings, leading to better engagement and trust."
    },
    "accentColor": "#E0F6FC",
    "localizationInfo": {
        "defaultLanguageTag": "en-US",
        "additionalLanguages": [
            { "languageTag": "cs-CZ", "file": "loc/manifest.cs-CZ.json" },
            { "languageTag": "da-DK", "file": "loc/manifest.da-DK.json" },
            { "languageTag": "de-DE", "file": "loc/manifest.de-DE.json" },
            { "languageTag": "el-GR", "file": "loc/manifest.el-GR.json" },
            { "languageTag": "en-US", "file": "loc/manifest.en-US.json" },
            { "languageTag": "es-ES", "file": "loc/manifest.es-ES.json" },
            { "languageTag": "es-US", "file": "loc/manifest.es-US.json" },
            { "languageTag": "fi-FI", "file": "loc/manifest.fi-FI.json" },
            { "languageTag": "fr-CA", "file": "loc/manifest.fr-CA.json" },
            { "languageTag": "fr-FR", "file": "loc/manifest.fr-FR.json" },
            { "languageTag": "hi-IN", "file": "loc/manifest.hi-IN.json" },
            { "languageTag": "id-ID", "file": "loc/manifest.id-ID.json" },
            { "languageTag": "it-IT", "file": "loc/manifest.it-IT.json" },
            { "languageTag": "ja-JP", "file": "loc/manifest.ja-JP.json" },
            { "languageTag": "ko-KR", "file": "loc/manifest.ko-KR.json" },
            { "languageTag": "nb-NO", "file": "loc/manifest.nb-NO.json" },
            { "languageTag": "nl-NL", "file": "loc/manifest.nl-NL.json" },
            { "languageTag": "pl-PL", "file": "loc/manifest.pl-PL.json" },
            { "languageTag": "pt-BR", "file": "loc/manifest.pt-BR.json" },
            { "languageTag": "ru-RU", "file": "loc/manifest.ru-RU.json" },
            { "languageTag": "sv-SE", "file": "loc/manifest.sv-SE.json" },
            { "languageTag": "th-TH", "file": "loc/manifest.th-TH.json" },
            { "languageTag": "tr-TR", "file": "loc/manifest.tr-TR.json" },
            { "languageTag": "zh-CN", "file": "loc/manifest.zh-CN.json" },
            { "languageTag": "zh-TW", "file": "loc/manifest.zh-TW.json" }
        ]
    },
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
