# Microsoft 365 Agents Toolkit environment file (dev)
# Populated by `teamsapp provision` / `wiqd agent provision --env dev`.
# Safe to commit (no secrets). User-specific overrides go in .env.dev.user (gitignored).

TEAMSFX_ENV=dev
APP_NAME_SUFFIX=-dev

