# Copy this file to .env.dev and fill in the values below.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev

# Generated during provision by Microsoft 365 Agents Toolkit
TEAMS_APP_ID=
TEAMS_APP_TENANT_ID=
M365_TITLE_ID=
M365_APP_ID=

# SharePoint Configuration
# Format: hostname,siteCollectionId,siteId (e.g., contoso.sharepoint.com,12345678-...,abcdef...)
SHAREPOINT_SITE_ID=

# SharePoint List ID for "Volunteer Commitments" list (GUID)
# Example: 12345678-1234-1234-1234-123456789012
SHAREPOINT_LIST_ID=

# OAuth Plugin Vault Reference ID - from Teams Developer Portal OAuth client registration
OAUTH_REFERENCE_ID=
