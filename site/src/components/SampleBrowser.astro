---
import type { SampleEntry } from "../lib/samples";

interface Props {
  samples: SampleEntry[];
  byType: Record<string, number>;
}

const { samples, byType } = Astro.props;
const sortedTypes = Object.keys(byType).sort((a, b) => a.localeCompare(b));
---

<section id="browse" class="space-y-5">
  <div class="frost-panel p-4 md:p-5">
    <h2 class="text-2xl font-bold text-white">Sample Browser</h2>
    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-300">
      Filter by type and search by title, folder, or description.
    </p>

    <div class="mt-4 flex flex-wrap gap-3">
      <input
        id="sample-search"
        class="w-full flex-1 rounded-xl border border-white/20 bg-ink-900/80 px-4 py-3 text-sm text-slate-100 outline-none ring-sky-300/50 transition placeholder:text-slate-400 focus:ring-2"
        type="search"
        placeholder="Search by folder, title, or description..."
      />
      <div class="flex flex-wrap gap-2" id="type-pills">
        <button type="button" class="chip-button chip-button-active pill" data-type="all">All</button>
        {sortedTypes.map((type) => (
          <button type="button" class="chip-button pill" data-type={type}>{type}</button>
        ))}
      </div>
    </div>
  </div>

  <div id="samples-grid" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
    {samples.map((sample) => (
      <a
        href={`/samples/${sample.folder}`}
        class="sample-card theme-card-hover frost-panel grid gap-3 p-4 transition hover:-translate-y-0.5"
        data-title={sample.title.toLowerCase()}
        data-folder={sample.folder.toLowerCase()}
        data-description={sample.description.toLowerCase()}
        data-type={sample.type}
      >
        <div class="sample-type-pill" data-sample-type={sample.type}>
          {sample.type}
        </div>
        <h3 class="text-lg font-semibold text-white">{sample.title}</h3>
        <p class="text-sm leading-relaxed text-slate-300">{sample.description}</p>
        <div class="text-xs text-slate-400">Folder: {sample.folder}</div>
        <div class="text-xs text-slate-400">
          Last updated: {sample.updatedAt ? sample.updatedAt.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) : "Unknown"}
        </div>
        <span class="theme-link text-sm font-semibold">View sample details</span>
      </a>
    ))}
    <div id="empty-state" class="frost-panel hidden border-[#ea5c9c]/55 bg-[#ea5c9c]/20 p-4 text-sm text-[#ffd7e7]">
      No samples match this search/filter combination.
    </div>
  </div>
</section>

<script>
  import { initSampleBrowser } from "../scripts/sample-browser";

  initSampleBrowser();
</script>
