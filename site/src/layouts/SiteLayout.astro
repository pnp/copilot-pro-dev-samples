---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Microsoft 365 Copilot community samples browser." } = Astro.props;
const navItems = [
  {
    href: "/",
    label: "Home",
    icon: "M12 3.5l8.5 7.2a1 1 0 01.35.76V20a1 1 0 01-1 1H15a1 1 0 01-1-1v-4h-4v4a1 1 0 01-1 1H4.15a1 1 0 01-1-1v-8.54a1 1 0 01.35-.76L12 3.5z",
  },
  {
    href: "/samples",
    label: "Samples",
    icon: "M3.5 6.5A2.5 2.5 0 016 4h12a2.5 2.5 0 012.5 2.5v11A2.5 2.5 0 0118 20H6a2.5 2.5 0 01-2.5-2.5v-11zm4 1a1 1 0 000 2h9a1 1 0 100-2h-9zm0 4a1 1 0 000 2h9a1 1 0 100-2h-9zm0 4a1 1 0 100 2h5a1 1 0 100-2h-5z",
  },
  {
    href: "/about",
    label: "Contributing",
    icon: "M7 5a3 3 0 110 6 3 3 0 010-6zm10 1a2.5 2.5 0 110 5 2.5 2.5 0 010-5zM4 14a4 4 0 014-4h0a4 4 0 014 4v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2zm10 2.2V14a5.9 5.9 0 00-.95-3.2h1.95a4 4 0 014 4v1.4a.6.6 0 01-.6.6H14.6a.6.6 0 01-.6-.6z",
  },
];
const repoIcon = "M12 .9A11.1 11.1 0 00.9 12a11.1 11.1 0 007.6 10.53c.56.1.76-.24.76-.54v-1.9c-3.08.67-3.73-1.48-3.73-1.48-.5-1.3-1.24-1.65-1.24-1.65-1.02-.7.08-.69.08-.69 1.12.08 1.71 1.16 1.71 1.16 1 .1 1.65-.73 2.02-1.14.1-.74.39-1.24.71-1.53-2.45-.29-5.03-1.25-5.03-5.56 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.43.1-2.98 0 0 .95-.31 3.1 1.16a10.7 10.7 0 015.64 0c2.15-1.47 3.1-1.16 3.1-1.16.6 1.55.22 2.7.1 2.98.72.79 1.16 1.8 1.16 3.03 0 4.32-2.59 5.27-5.06 5.55.4.35.76 1.03.76 2.08V22c0 .3.2.64.77.54A11.1 11.1 0 0023.1 12 11.1 11.1 0 0012 .9z";
const currentPath = Astro.url.pathname === "/" ? "/" : Astro.url.pathname.replace(/\/$/, "");
const siteTitle = "Copilot Pro Dev Samples";
const documentTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{documentTitle}</title>
  </head>
  <body>
    <header class="sticky top-0 z-30 border-b border-white/10 bg-ink-950/70 backdrop-blur-lg">
      <div class="mx-auto flex h-20 w-full max-w-6xl items-center justify-between gap-4 px-4 md:px-6">
        <a class="text-lg font-bold tracking-wide text-white" href="/">Copilot <span class="text-sky-300">Pro Dev Samples</span></a>
        <nav class="flex items-center gap-2 md:gap-3">
          {navItems.map((item) => {
            const isCurrent = currentPath === item.href;
            return (
              <a
                href={item.href}
                class:list={[
                  "chip-button inline-flex items-center gap-2 text-xs md:text-sm",
                  isCurrent && "chip-button-active",
                ]}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-current">
                  <path d={item.icon}></path>
                </svg>
                {item.label}
              </a>
            );
          })}
          <a
            href="https://github.com/pnp/copilot-pro-dev-samples"
            target="_blank"
            rel="noreferrer"
            class="chip-button hidden items-center gap-2 border-lime-300/70 text-lime-200 sm:inline-flex"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-current">
              <path d={repoIcon}></path>
            </svg>
            Repo
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl px-4 py-10 md:px-6 md:py-14">
      <slot />
    </main>

    <footer class="border-t border-white/10 py-8 text-sm text-slate-300">
      <div class="mx-auto w-full max-w-6xl px-4 md:px-6">
        This site and samples run under MIT License. These samples are provided as is without warranty of any kind, either express or implied, including any implied warranties of fitness for a particular purpose, merchantability, or non-infringement.
      </div>
    </footer>
  </body>
</html>
