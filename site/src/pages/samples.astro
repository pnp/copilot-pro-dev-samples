---
import SiteLayout from "../layouts/SiteLayout.astro";
import SampleBrowser from "../components/SampleBrowser.astro";
import { getSamples, getSampleStats } from "../lib/samples";

const samples = await getSamples();
const { byType, total } = getSampleStats(samples);
---

<SiteLayout title="Browse Samples" description="Filter and browse Microsoft 365 Copilot sample projects.">
  <section class="mb-8 space-y-3">
    <p class="theme-eyebrow text-xs font-semibold uppercase tracking-[0.2em]">Catalog</p>
    <h1 class="text-4xl font-extrabold text-white md:text-5xl">Browse {total} community samples</h1>
    <p class="max-w-2xl text-base text-slate-300">
      Search by keyword and narrow by sample type to quickly reach the implementation you need.
    </p>
  </section>

  <SampleBrowser samples={samples} byType={byType} />
</SiteLayout>
