---
import SiteLayout from "../layouts/SiteLayout.astro";
import LatestSamples from "../components/LatestSamples.astro";
import { getLatestSamples, getSamples, getSampleStats } from "../lib/samples";

const samples = await getSamples();
const latestSamplesWindowMonths = 1;
const latestSamples = getLatestSamples(samples, latestSamplesWindowMonths);
const { total, topTypes } = getSampleStats(samples);
---

<SiteLayout title="Copilot Pro Dev Samples" description="Explore Microsoft 365 Copilot community samples.">
  <section class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
    <div class="space-y-5">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-lime-200">Open Source Agent Catalog</p>
      <h1 class="max-w-xl text-4xl font-extrabold leading-tight text-white md:text-6xl">
        Explore beyond the
        <span class="bg-gradient-to-r from-cyan-200 to-sky-300 bg-clip-text text-transparent"> hello world</span>.
      </h1>
      <p class="max-w-2xl text-base leading-relaxed text-slate-300 md:text-lg">
        Browse real Microsoft 365 Copilot samples by agent type, scan metadata quickly, and jump directly into source folders.
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="chip-button border-cyan-300 bg-cyan-300 text-slate-950" href="/samples">Browse Samples</a>
        <a class="chip-button" href="/about">How It Works</a>
      </div>
    </div>

    <div class="frost-panel grid gap-3 p-4 md:p-6">
      <h2 class="text-xl font-bold text-white">Quick Stats</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <article class="rounded-xl border border-white/15 bg-white/3 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-300">Total Samples</p>
          <p class="mt-2 text-3xl font-bold text-white">{total}</p>
        </article>
        <article class="rounded-xl border border-white/15 bg-white/3 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-300">Top Type</p>
          <p class="mt-2 text-base font-semibold text-white">{topTypes[0] ? `${topTypes[0][0]} (${topTypes[0][1]})` : "N/A"}</p>
        </article>
        <article class="rounded-xl border border-white/15 bg-white/3 p-4 sm:col-span-2">
          <p class="text-xs uppercase tracking-wide text-slate-300">Second + Third</p>
          <p class="mt-2 text-base font-semibold text-white">
            {topTypes[1] ? `${topTypes[1][0]} (${topTypes[1][1]})` : "N/A"}
            <span class="mx-2 text-slate-500">|</span>
            {topTypes[2] ? `${topTypes[2][0]} (${topTypes[2][1]})` : "N/A"}
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <LatestSamples samples={latestSamples} months={latestSamplesWindowMonths} />
  </section>
</SiteLayout>
