---
import { readdir, readFile } from "node:fs/promises";
import path from "node:path";

type SampleEntry = {
	folder: string;
	title: string;
	description: string;
	type: string;
	href: string;
};

const samplesRoot = path.resolve(Astro.url.pathname ? process.cwd() : process.cwd(), "..", "samples");

const typeLabels: Record<string, string> = {
	da: "Declarative Agent",
	cea: "Custom Engine Agent",
	cext: "Copilot Extension",
	mcp: "MCP",
	mcs: "Copilot Studio",
};

const rawDirs = await readdir(samplesRoot, { withFileTypes: true });

const folders = rawDirs
	.filter((entry) => entry.isDirectory())
	.map((entry) => entry.name)
	.filter((name) => !name.startsWith(".") && name !== "_SAMPLE_templates")
	.sort((a, b) => a.localeCompare(b));

const samples: SampleEntry[] = await Promise.all(
	folders.map(async (folder) => {
		const sampleJsonPath = path.join(samplesRoot, folder, "assets", "sample.json");
		let title = folder;
		let description = "Community sample for Microsoft 365 Copilot developers.";

		try {
			const raw = await readFile(sampleJsonPath, "utf8");
			const parsed = JSON.parse(raw);
			if (Array.isArray(parsed) && parsed[0]) {
				title = parsed[0].title || parsed[0].name || title;
				description = parsed[0].shortDescription || description;
			}
		} catch {
			// Fallbacks are used when metadata file is missing or invalid.
		}

		const typeKey = folder.split("-")[0] || "other";
		const type = typeLabels[typeKey] || "Other";

		return {
			folder,
			title,
			description,
			type,
			href: `https://github.com/pnp/copilot-pro-dev-samples/tree/main/samples/${folder}`,
		};
	})
);

const total = samples.length;
const byType = samples.reduce<Record<string, number>>((acc, sample) => {
	acc[sample.type] = (acc[sample.type] || 0) + 1;
	return acc;
}, {});

const topTypes = Object.entries(byType)
	.sort((a, b) => b[1] - a[1])
	.slice(0, 3);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Copilot Samples Browser</title>
		<style>
			:root {
				--bg: #050816;
				--bg-soft: #0a1330;
				--panel: #0d1b3a;
				--line: #233661;
				--text: #ecf3ff;
				--muted: #9fb2d8;
				--accent: #25d0ff;
				--accent-2: #18f3a9;
				--highlight: #ffd24a;
				--danger: #ff5b7f;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				font-family: "Space Grotesk", "Avenir Next", "Segoe UI", sans-serif;
				background:
					radial-gradient(circle at 75% -10%, rgba(37, 208, 255, 0.18), transparent 40%),
					radial-gradient(circle at 20% 15%, rgba(24, 243, 169, 0.12), transparent 45%),
					linear-gradient(180deg, #050816 0%, #041128 35%, #050816 100%);
				color: var(--text);
				min-height: 100vh;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.container {
				width: min(1120px, calc(100% - 2rem));
				margin: 0 auto;
			}

			header {
				position: sticky;
				top: 0;
				z-index: 30;
				backdrop-filter: blur(10px);
				background: rgba(5, 8, 22, 0.75);
				border-bottom: 1px solid rgba(159, 178, 216, 0.15);
			}

			.nav {
				height: 70px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.brand {
				font-size: 1.1rem;
				font-weight: 700;
				letter-spacing: 0.03em;
			}

			.brand span {
				color: var(--accent);
			}

			.nav-actions {
				display: flex;
				gap: 0.6rem;
			}

			.btn {
				border-radius: 999px;
				padding: 0.55rem 1rem;
				border: 1px solid var(--line);
				font-weight: 600;
				font-size: 0.9rem;
				transition: transform 0.25s ease, border-color 0.25s ease;
			}

			.btn:hover {
				transform: translateY(-1px);
				border-color: var(--accent);
			}

			.btn.primary {
				background: linear-gradient(90deg, var(--accent), var(--accent-2));
				color: #041126;
				border-color: transparent;
			}

			.hero {
				padding: 5.5rem 0 2.8rem;
				display: grid;
				gap: 2rem;
			}

			.eyebrow {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				color: var(--accent-2);
			}

			h1 {
				margin: 0.5rem 0 0;
				font-size: clamp(2.5rem, 7vw, 4.6rem);
				line-height: 0.98;
				max-width: 12ch;
			}

			h1 .accent {
				color: var(--accent);
			}

			.hero p {
				max-width: 70ch;
				font-size: 1.05rem;
				line-height: 1.65;
				color: var(--muted);
			}

			.stats {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 0.8rem;
			}

			.stat {
				background: linear-gradient(150deg, rgba(13, 27, 58, 0.95), rgba(7, 18, 38, 0.95));
				border: 1px solid rgba(159, 178, 216, 0.18);
				border-radius: 14px;
				padding: 1rem;
			}

			.stat .label {
				font-size: 0.76rem;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--muted);
			}

			.stat .value {
				font-size: 1.6rem;
				font-weight: 700;
				margin-top: 0.35rem;
			}

			.section-title {
				margin-top: 1rem;
				font-size: 1.5rem;
			}

			.controls {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
				margin: 1rem 0 1.4rem;
			}

			.search {
				flex: 1 1 250px;
				padding: 0.75rem 0.9rem;
				border-radius: 10px;
				border: 1px solid rgba(159, 178, 216, 0.25);
				background: rgba(8, 18, 39, 0.8);
				color: var(--text);
				font: inherit;
			}

			.search:focus {
				outline: 2px solid rgba(37, 208, 255, 0.5);
				border-color: var(--accent);
			}

			.pills {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}

			.pill {
				border-radius: 999px;
				border: 1px solid var(--line);
				background: rgba(13, 27, 58, 0.7);
				color: var(--muted);
				padding: 0.45rem 0.8rem;
				cursor: pointer;
				font: inherit;
				font-size: 0.86rem;
			}

			.pill.active {
				color: #041126;
				background: linear-gradient(90deg, var(--accent), var(--accent-2));
				border-color: transparent;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.85rem;
				padding-bottom: 5rem;
			}

			.card {
				border-radius: 14px;
				padding: 1rem;
				border: 1px solid rgba(159, 178, 216, 0.2);
				background: linear-gradient(160deg, rgba(13, 27, 58, 0.92), rgba(8, 18, 39, 0.92));
				display: grid;
				gap: 0.7rem;
				transition: transform 0.25s ease, border-color 0.25s ease;
			}

			.card:hover {
				transform: translateY(-3px);
				border-color: rgba(37, 208, 255, 0.55);
			}

			.tag {
				display: inline-flex;
				align-items: center;
				width: fit-content;
				border-radius: 999px;
				padding: 0.28rem 0.6rem;
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #041126;
				background: linear-gradient(90deg, var(--highlight), #ffe9a2);
			}

			.card h3 {
				margin: 0;
				font-size: 1rem;
			}

			.card p {
				margin: 0;
				color: var(--muted);
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.card .meta {
				font-size: 0.78rem;
				color: #87a3d4;
			}

			.card .link {
				font-size: 0.85rem;
				color: var(--accent);
				font-weight: 600;
			}

			.empty {
				grid-column: 1 / -1;
				border: 1px dashed rgba(255, 91, 127, 0.5);
				border-radius: 12px;
				padding: 1rem;
				color: #ffc4d1;
				background: rgba(36, 11, 22, 0.5);
				display: none;
			}

			footer {
				border-top: 1px solid rgba(159, 178, 216, 0.15);
				padding: 1.3rem 0 2.5rem;
				color: var(--muted);
				font-size: 0.86rem;
			}

			@media (max-width: 980px) {
				.stats {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 680px) {
				.nav {
					height: auto;
					padding: 0.9rem 0;
					gap: 0.8rem;
					flex-wrap: wrap;
				}

				.hero {
					padding-top: 3.2rem;
				}

				.stats,
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<header>
			<div class="container nav">
				<a class="brand" href="#top">Copilot <span>Samples</span></a>
				<div class="nav-actions">
					<a class="btn" href="https://github.com/pnp/copilot-pro-dev-samples" target="_blank" rel="noreferrer">Repository</a>
					<a class="btn primary" href="#browse">Browse now</a>
				</div>
			</div>
		</header>

		<main class="container" id="top">
			<section class="hero">
				<div>
					<div class="eyebrow">Open Source Agent Catalog</div>
					<h1>Explore beyond the <span class="accent">hello world</span>.</h1>
					<p>
						Browse real Microsoft 365 Copilot samples by agent type, scan metadata instantly,
						and jump straight to implementation folders in GitHub.
					</p>
				</div>
				<div class="stats">
					<div class="stat">
						<div class="label">Total Samples</div>
						<div class="value">{total}</div>
					</div>
					<div class="stat">
						<div class="label">Top Type</div>
						<div class="value">{topTypes[0] ? `${topTypes[0][0]} (${topTypes[0][1]})` : "N/A"}</div>
					</div>
					<div class="stat">
						<div class="label">Second Type</div>
						<div class="value">{topTypes[1] ? `${topTypes[1][0]} (${topTypes[1][1]})` : "N/A"}</div>
					</div>
					<div class="stat">
						<div class="label">Curated For</div>
						<div class="value">M365 Devs</div>
					</div>
				</div>
			</section>

			<section id="browse">
				<h2 class="section-title">Sample Browser</h2>
				<div class="controls">
					<input
						id="sample-search"
						class="search"
						type="search"
						placeholder="Search by folder, title, or description..."
					/>
					<div class="pills" id="type-pills">
						<button type="button" class="pill active" data-type="all">All</button>
						{Object.keys(byType)
							.sort((a, b) => a.localeCompare(b))
							.map((type) => (
								<button type="button" class="pill" data-type={type}>{type}</button>
							))}
					</div>
				</div>

				<div class="grid" id="samples-grid">
					{samples.map((sample) => (
						<article
							class="card"
							data-title={sample.title.toLowerCase()}
							data-folder={sample.folder.toLowerCase()}
							data-description={sample.description.toLowerCase()}
							data-type={sample.type}
						>
							<div class="tag">{sample.type}</div>
							<h3>{sample.title}</h3>
							<p>{sample.description}</p>
							<div class="meta">Folder: {sample.folder}</div>
							<a class="link" href={sample.href} target="_blank" rel="noreferrer">Open in GitHub</a>
						</article>
					))}
					<div class="empty" id="empty-state">No samples match this search/filter combination.</div>
				</div>
			</section>
		</main>

		<footer>
			<div class="container">
				Built from local folder structure in <strong>/samples</strong>. Refresh after adding new samples.
			</div>
		</footer>

		<script>
			const search = document.querySelector("#sample-search");
			const pills = Array.from(document.querySelectorAll("#type-pills .pill"));
			const cards = Array.from(document.querySelectorAll("#samples-grid .card"));
			const empty = document.querySelector("#empty-state");
			let activeType = "all";

			const applyFilters = () => {
				const query = (search?.value || "").trim().toLowerCase();
				let visible = 0;

				for (const card of cards) {
					const byType = activeType === "all" || card.dataset.type === activeType;
					const haystack = `${card.dataset.title} ${card.dataset.folder} ${card.dataset.description}`;
					const byQuery = haystack.includes(query);
					const show = byType && byQuery;

					card.style.display = show ? "grid" : "none";
					if (show) visible += 1;
				}

				if (empty) {
					empty.style.display = visible === 0 ? "block" : "none";
				}
			};

			search?.addEventListener("input", applyFilters);

			for (const pill of pills) {
				pill.addEventListener("click", () => {
					activeType = pill.dataset.type || "all";
					for (const item of pills) {
						item.classList.toggle("active", item === pill);
					}
					applyFilters();
				});
			}

			applyFilters();
		</script>
	</body>
</html>
